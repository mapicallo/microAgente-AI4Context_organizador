{
  "manifest_version": 3,
  "name": "MicroAgente-AI4Context (organizador)",
  "version": "0.1.0",
  "description": "Orquestador de micro-agentes AI4Context: planes locales, agentes registrados, tubo demo (eco, mayúsculas, líneas).",
  "action": {
    "default_title": "MicroAgente-AI4Context — organizador",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "permissions": ["storage", "windows"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
